generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum ContractStatus {
  DRAFT
  ACTIVE
  PENDING
  CANCELLED
  FINISHED
}

enum PaymentMethod {
  PIX
  BOLETO
  CARTAO_RECORRENTE
  DINHEIRO
  TRANSFERENCIA
}

enum PaymentStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum PropertyStatus {
  DISPONIVEL
  ALUGADO
  MANUTENCAO
  INATIVO
}

enum RenterStatus {
  ATIVO
  INATIVO
  BLOQUEADO
}

//////////////////////////////////////////////////
// TENANT (IMOBILIÁRIA)
//////////////////////////////////////////////////

model Tenant {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  cnpj    String? @unique
  phone   String?
  email   String?
  logoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  properties Property[]
  renters    Renter[]
  contracts  Contract[]
  payments   Payment[]
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String  @unique
  password String
  role     String  @default("USER")
  isActive Boolean @default(true)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  contracts Contract[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

//////////////////////////////////////////////////
// PROPERTY (IMÓVEL)
//////////////////////////////////////////////////

model Property {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  city         String
  state        String
  zipCode      String
  street       String
  neighborhood String
  number       String
  sqls         String
  status       PropertyStatus @default(DISPONIVEL)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  renters   Renter[]
  contracts Contract[]
  documents PropertyDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

//////////////////////////////////////////////////
// PROPERTY DOCUMENT (DOCUMENTOS DO IMÓVEL)
//////////////////////////////////////////////////

model PropertyDocument {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  fileName     String
  originalName String?
  fileUrl      String
  storageKey   String?
  mimeType     String?
  size         Int?

  propertyId String   @db.ObjectId
  property   Property @relation(fields: [propertyId], references: [id])

  createdAt DateTime @default(now())

  @@index([propertyId])
}

//////////////////////////////////////////////////
// RENTER (INQUILINO)
//////////////////////////////////////////////////

model Renter {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  email       String?
  phone       String?
  cpf         String? @unique
  documentUrl String?
  notes       String?

  status RenterStatus @default(ATIVO)

  propertyId String?   @db.ObjectId
  property   Property? @relation(fields: [propertyId], references: [id])

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  contracts Contract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

//////////////////////////////////////////////////
// CONTRACT (CONTRATO)
//////////////////////////////////////////////////

model Contract {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  contractNumber String?

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  propertyId String   @db.ObjectId
  property   Property @relation(fields: [propertyId], references: [id])

  renterId String @db.ObjectId
  renter   Renter @relation(fields: [renterId], references: [id])

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  rentAmount   Float
  dueDay       Int
  startDate    DateTime
  endDate      DateTime?
  depositValue Float?

  paymentMethod PaymentMethod
  status        ContractStatus @default(DRAFT)

  notes String?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([propertyId]) 
  @@index([renterId])
  @@index([status])
}

//////////////////////////////////////////////////
// PAYMENT (PAGAMENTO)
//////////////////////////////////////////////////

model Payment {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  amount         Float
  referenceMonth String
  dueDate        DateTime
  paymentDate    DateTime?
  method         PaymentMethod
  status         PaymentStatus @default(PENDENTE)
  receiptUrl     String?
  notes          String?

  contractId String   @db.ObjectId
  contract   Contract @relation(fields: [contractId], references: [id])

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([tenantId])
  @@index([status])
  @@index([referenceMonth])
}