generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum ContractStatus {
  DRAFT
  ACTIVE
  PENDING
  CANCELLED
  FINISHED
}

enum PaymentMethod {
  PIX
  BOLETO
  CARTAO_RECORRENTE
  DINHEIRO
  TRANSFERENCIA
}

enum PaymentStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum PropertyStatus {
  DISPONIVEL
  ALUGADO
  MANUTENCAO
  INATIVO
}

enum RenterStatus {
  ATIVO
  INATIVO
  BLOQUEADO
}

enum DocumentType {
  CONTRATO
  RG
  CPF
  COMPROVANTE_RENDA
  COMPROVANTE_ENDERECO
  OUTRO
}

//////////////////////////////////////////////////
// TENANT (IMOBILIÁRIA)
//////////////////////////////////////////////////

model Tenant {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  cnpj    String? @unique
  phone   String?
  email   String? @unique
  logoUrl String?

  // 🔥 CONTROLE SAAS
  isActive Boolean @default(true)

  // Relacionamentos
  users      User[]
  properties Property[]
  renters    Renter[]
  contracts  Contract[]
  payments   Payment[]
  documents  Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cnpj])
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String  @unique
  password String

  role     String  @default("USER") // ADMIN | MANAGER | USER
  isActive Boolean @default(true)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contracts Contract[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([email])
}

//////////////////////////////////////////////////
// PROPERTY
//////////////////////////////////////////////////

model Property {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  address     String
  city        String?
  state       String?
  zipCode     String?

  price  Float?
  status PropertyStatus @default(DISPONIVEL)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  renters   Renter[]
  contracts Contract[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([city])
}

//////////////////////////////////////////////////
// RENTER
//////////////////////////////////////////////////

model Renter {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  email       String?
  phone       String?
  cpf         String? @unique
  documentUrl String?
  notes       String?

  status RenterStatus @default(ATIVO)

  propertyId String?   @db.ObjectId
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contracts Contract[]
  documents Document[]
  payments  Payment[]   // 🔥 ADICIONADO (IMPORTANTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([cpf])
  @@index([status])
}

//////////////////////////////////////////////////
// CONTRACT
//////////////////////////////////////////////////

model Contract {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  contractNumber String? @unique

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String   @db.ObjectId
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  renterId String @db.ObjectId
  renter   Renter @relation(fields: [renterId], references: [id], onDelete: Cascade)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rentAmount    Float
  dueDay        Int
  startDate     DateTime
  endDate       DateTime?
  depositValue  Float?

  paymentMethod PaymentMethod
  status        ContractStatus @default(DRAFT)

  notes String?

  payments  Payment[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([propertyId])
  @@index([renterId])
  @@index([status])
}

//////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////

model Payment {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  amount      Float
  referenceMonth String
  dueDate     DateTime
  paymentDate DateTime?

  method PaymentMethod
  status PaymentStatus @default(PENDENTE)

  receiptUrl String?
  notes      String?

  daysOverdue Int @default(0)

  contractId String   @db.ObjectId
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  renterId String @db.ObjectId
  renter   Renter @relation(fields: [renterId], references: [id], onDelete: Cascade)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([referenceMonth])
  @@index([dueDate])
}

//////////////////////////////////////////////////
// DOCUMENT
//////////////////////////////////////////////////

model Document {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  type       DocumentType
  url        String
  fileSize   Int
  mimeType   String

  uploadedBy String // 🔥 manter simples (email)

  contractId String?   @db.ObjectId
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)

  paymentId String?  @db.ObjectId
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  renterId String?  @db.ObjectId
  renter   Renter? @relation(fields: [renterId], references: [id], onDelete: Cascade)

  propertyId String?  @db.ObjectId
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([type])
}