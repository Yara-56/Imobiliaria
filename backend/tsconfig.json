{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",

    "rootDir": ".", 
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@infra/*": ["src/modules/*"]
    },

    /* Se o erro persistir, remova "vitest/globals" daqui e use o Passo 3 */
    "types": ["node", "vitest"], 

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,

    "sourceMap": true,
    "incremental": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },

  "include": [
    "src/**/*.ts", 
    "src/**/*.d.ts",
    "prisma/**/*.ts", 
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules", 
    "dist"
  ]
}