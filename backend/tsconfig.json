{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "ignoreDeprecations": "6.0",

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@modules/*": ["modules/*"],
      "@shared/*": ["shared/*"],
      "@infra/*": ["modules/*"]
    },

    "typeRoots": ["./src/@types", "./node_modules/@types"],
    "types": ["node"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,

    "lib": ["ES2022"],
    "incremental": true
  },

  "include": ["src", "prisma"],
  "exclude": ["node_modules", "dist"]
}