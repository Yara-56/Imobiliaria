{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    /* 🔥 ESSENCIAL PARA ALIAS */
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },

    /* QUALIDADE */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,

    /* NODE */
    "lib": ["ES2022"],
    "types": ["node"]
  },

  "include": ["src", "prisma"],
  "exclude": ["node_modules", "dist"]
}