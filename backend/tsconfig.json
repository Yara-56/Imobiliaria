{
  "compilerOptions": {
    /* 🎯 Versão e Módulos Modernos */
    "target": "ES2022",
    "lib": ["ES2022", "ESNext.AsyncIterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "isolatedModules": true,

    /* ✅ Silencia o aviso de depreciação conforme sugerido */
    "ignoreDeprecations": "5.0",

    /* 📂 Estrutura de Pastas */
    "rootDir": "./src",
    "outDir": "./dist",

    /* 🚀 Paths (mantido igual ao seu) */
    "paths": {
      "@/*": ["./src/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"],
      "@infra/*": ["./src/modules/*"]
    },

    /* 🔍 Tipagem e Definições Globais */
    "typeRoots": ["./src/@types", "./node_modules/@types"],
    "types": ["node", "jest"],
    "resolveJsonModule": true,

    /* 🛡️ Rigor de Tipagem */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "incremental": true,

    /* 🔥 Decorators */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },

  "include": [
    "src/**/*",
    "src/@types/*.d.ts",
    "prisma/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}