{
  "compilerOptions": {
    /* 🎯 Versão e Módulos Modernos */
    "target": "ES2022",
    "lib": ["ES2022", "ESNext.AsyncIterable"],
    "module": "NodeNext", 
    "moduleResolution": "NodeNext",
    
    /* ✅ Silencia o aviso de depreciação conforme sugerido */
    "ignoreDeprecations": "5.0",

    /* 📂 Estrutura de Pastas */
    "rootDir": "./src",
    "outDir": "./dist",

    /* 🚀 A SOLUÇÃO: 
       Removemos a dependência do baseUrl para resolução de módulos.
       Agora os caminhos (@/) apontam diretamente para onde os arquivos estão
       em relação à raiz do projeto.
    */
    "paths": {
      "@/*": ["./src/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"],
      "@infra/*": ["./src/modules/*"]
    },

    /* 🔍 Tipagem e Definições Globais */
    "typeRoots": ["./src/@types", "./node_modules/@types"],
    "types": ["node"],
    "resolveJsonModule": true,

    /* 🛡️ Rigor de Tipagem (Nível Profissional) */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false, 
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "incremental": true,

    /* 🔥 Decorators (Essenciais para Tsyringe/Inversify) */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },

  "include": [
    "src/**/*",         
    "src/@types/*.d.ts", 
    "prisma/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}