{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],

    "module": "commonjs",
    "moduleResolution": "node10",

    "ignoreDeprecations": "6.0",

    "rootDir": "src",
    "outDir": "dist",

    "paths": {
      "@/*": ["src/*"],
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@infra/*": ["src/modules/*"]
    },

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "incremental": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}