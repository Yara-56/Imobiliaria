{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    /* Configurações de Módulo para Node Moderno (ESM) */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    /* 🔥 RESOLVE O ERRO 'Transform failed' (Decorators) */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Paths e Resolução */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@infra/*": ["src/modules/*"]
    },

    "rootDir": "src",
    "outDir": "dist",

    /* Interoperabilidade e Segurança */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    
    /* ✅ RESOLVE O ERRO 'id não tem inicializador' (ts2564) */
    "strictPropertyInitialization": false,
    
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}