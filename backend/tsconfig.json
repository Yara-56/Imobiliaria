{
  "compilerOptions": {
    /* --- Core Compiler Settings --- */
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",

    /* --- Path Mapping (Modern Standard) --- */
    /* Removido 'baseUrl' para conformidade com TS 7.0+ */
    "paths": {
      "@/*": ["./src/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"],
      "@config/*": ["./src/config/*"],
      "@infra/*": ["./src/infrastructure/*"]
    },

    /* --- Dependency Injection Support --- */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* --- Strict Type-Checking & Security --- */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": false, // Facilitador para DI e ORMs (Prisma)
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,

    /* --- Linter-like Checks --- */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* --- Module Resolution & Interop --- */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true, 
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true, 
    
    /* --- Environment & Compatibility --- */
    "types": ["node", "reflect-metadata", "jest"],
    /* Silencia avisos de depreciação conforme sugerido pelo compilador */
    "ignoreDeprecations": "6.0" 
  },
  "include": [
    "src/**/*", 
    "prisma.config.ts", 
    "@types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules", 
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}