# Conexão com o MongoDB
MONGO_URI=mongodb://localhost:27017/imobiliaria  # Altere para sua URL de produção, se necessário

# Chave secreta do JWT (recomendação: use uma chave secreta mais segura em produção)
JWT_SECRET=um-valor-super-secreto-aleatorio  # Geração de chave secreta mais segura

# Porta do servidor
PORT=5050

# Variável de ambiente para controle do modo de desenvolvimento (Vite)
VITE_MODO_DEV=true  # Altere para false em produção
