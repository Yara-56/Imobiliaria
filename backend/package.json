{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "description": "API Backend - Imobiliária Yara Enterprise",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --watch src --ext ts,json --exec \"tsx -r tsconfig-paths/register src/server.ts\"",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "build": "tsc",
    "seed": "tsx -r tsconfig-paths/register src/seed.ts",
    "clean:trial": "tsx -r tsconfig-paths/register src/seed.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/lib-storage": "^3.893.0",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "dotenv-flow": "^4.1.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "handlebars": "^4.7.9",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-signpdf": "^3.0.0",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.18.0",
    "pino": "^9.0.0",
    "pino-http": "^9.0.0",
    "pix-utils": "^2.8.2",
    "playwright": "^1.58.2",
    "prisma": "^6.7.0",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-serve-static-core": "4.19.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.0",
    "pino-pretty": "^11.3.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
