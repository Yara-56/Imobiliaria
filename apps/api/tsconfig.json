{
  "compilerOptions": {
    /* --- Core Settings --- */
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",

    /* paths exige baseUrl; sem isto o tsc no CI pode falhar a resolver @shared/* */
    "baseUrl": ".",

    /* --- Path Mapping (SaaS PRO) --- */
    "paths": {
      "@/*": ["./src/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"],
      "@config/*": ["./src/config/*"],
      "@infra/*": ["./src/shared/infra/*"]
    },

    /* --- Modern Module Support --- */
    "noEmit": false,

    /* --- Dependency Injection --- */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* --- Strict --- */
    "strict": true,
    "noImplicitAny": true,
    "strictPropertyInitialization": false,

    /* --- Interop --- */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,

    /* --- Types --- */
    "types": ["node", "reflect-metadata"]
  },
  "include": ["src/**/*", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/prisma.config.ts"]
}
