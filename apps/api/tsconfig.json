{
  "compilerOptions": {
    /* --- Core Settings --- */
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./",
    "outDir": "./dist",

    /* --- Path Mapping (SaaS Pro) --- */
    // Removido o baseUrl para evitar o erro de depreciação. 
    // O TS agora resolve caminhos relativos ao arquivo de config.
    "paths": {
      "@/*": ["./src/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"],
      "@config/*": ["./src/config/*"],
      "@infra/*": ["./src/shared/infra/*"]
    },

    /* --- Modern Module Support --- */
    // Permite que você use imports terminando em .ts no seu routes.ts
    "allowImportingTsExtensions": true,
    "noEmit": true, 

    /* --- Dependency Injection Support --- */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* --- Strict Checks --- */
    "strict": true,
    "noImplicitAny": true,
    "strictPropertyInitialization": false,
    
    /* --- Interop & Environment --- */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    
    /* --- Types --- */
    "types": ["node", "reflect-metadata"]
  },
  "include": [
    "src/**/*",
    "prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}