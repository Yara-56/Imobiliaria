generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum ContractStatus {
  DRAFT
  ACTIVE
  PENDING
  CANCELLED
  FINISHED
}

enum PaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
  CASH
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  INACTIVE
}

enum DocumentType {
  IDENTITY_CARD
  TAX_ID
  INCOME_PROOF
  ADDRESS_PROOF
  LEASE_CONTRACT
  PAYMENT_RECEIPT
  PROPERTY_DEED
  PROPERTY_TAX
  INSURANCE_POLICY
  OTHER
}

//////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////

model Tenant {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  cnpj       String?  @unique
  isActive   Boolean  @default(true)

  users      User[]
  properties Property[]
  renters    Renter[]
  contracts  Contract[]
  payments   Payment[]
  documents  Document[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")

  tenantId  String   @db.ObjectId
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contracts Contract[]
  payments  Payment[]

  createdAt DateTime @default(now())
}

model Property {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  address    String
  price      Float          @default(0)
  status     PropertyStatus @default(AVAILABLE)

  tenantId   String         @db.ObjectId
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contracts  Contract[]
  documents  Document[]

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Renter {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName   String
  email      String?
  cpf        String?   @unique
  phone      String?

  tenantId   String    @db.ObjectId
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contracts  Contract[]
  documents  Document[]
  payments   Payment[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Contract {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  contractNumber String?        @unique

  startDate      DateTime
  endDate        DateTime?
  rentAmount     Float
  dueDay         Int
  status         ContractStatus @default(DRAFT)

  tenantId       String         @db.ObjectId
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId     String         @db.ObjectId
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  renterId       String         @db.ObjectId
  renter         Renter         @relation(fields: [renterId], references: [id], onDelete: Cascade)

  userId         String         @db.ObjectId
  user           User           @relation(fields: [userId], references: [id])

  payments       Payment[]
  documents      Document[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Payment {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  amount         Float
  dueDate        DateTime
  paymentDate    DateTime?
  status         PaymentStatus @default(PENDING)
  method         PaymentMethod @default(PIX)
  referenceMonth String

  contractId     String        @db.ObjectId
  contract       Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)

  renterId       String        @db.ObjectId
  renter         Renter        @relation(fields: [renterId], references: [id], onDelete: Cascade)

  tenantId       String        @db.ObjectId
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId         String?       @db.ObjectId
  user           User?         @relation(fields: [userId], references: [id])

  documents      Document[]

  createdAt      DateTime      @default(now())
}

model Document {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  type       DocumentType
  url        String
  fileKey    String
  fileSize   Int
  mimeType   String

  tenantId   String       @db.ObjectId
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String?      @db.ObjectId
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  renterId   String?      @db.ObjectId
  renter     Renter?      @relation(fields: [renterId], references: [id], onDelete: SetNull)

  contractId String?      @db.ObjectId
  contract   Contract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)

  paymentId  String?      @db.ObjectId
  payment    Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt  DateTime     @default(now())
}