generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

//////////////////////////////////////////////////
// ENUMS (Padrão Internacional)
//////////////////////////////////////////////////

enum ContractStatus {
  DRAFT      // Rascunho
  ACTIVE     // Vigente
  PENDING    // Aguardando Assinatura
  CANCELLED  // Rescindido
  FINISHED   // Finalizado/Encerrado
}

enum PaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
  CASH
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  INACTIVE
}

enum DocumentType {
  IDENTITY_CARD    // RG/CNH
  TAX_ID           // CPF
  INCOME_PROOF     // Holerite/IR
  ADDRESS_PROOF    // Conta de Luz/Água
  LEASE_CONTRACT   // Contrato de Locação Assinado
  PAYMENT_RECEIPT  // Recibo de Aluguel
  PROPERTY_DEED    // Escritura/Matrícula
  PROPERTY_TAX     // IPTU
  INSURANCE_POLICY // Seguro Incêndio/Fiança
  OTHER
}

//////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////

model Tenant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  cnpj      String?  @unique
  isActive  Boolean  @default(true)

  users      User[]
  properties Property[]
  renters    Renter[]
  contracts  Contract[]
  payments   Payment[]
  documents  Document[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")

  tenantId  String   @db.ObjectId
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contracts Contract[]
  payments  Payment[]
  
  createdAt DateTime @default(now())
}

model Property {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  address     String
  price       Float          @default(0)
  status      PropertyStatus @default(AVAILABLE)

  tenantId    String         @db.ObjectId
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contracts   Contract[]
  documents   Document[]     // Documentos do Imóvel (Escritura, Fotos, IPTU)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Renter {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  email       String?
  cpf         String?   @unique
  phone       String?

  tenantId    String    @db.ObjectId
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contracts   Contract[]
  documents   Document[] // Documentos do Inquilino (RG, CPF, Renda)
  payments    Payment[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Contract {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  contractNumber String?        @unique
  
  startDate      DateTime
  endDate        DateTime?
  rentAmount     Float
  dueDay         Int            // Dia de vencimento (1 a 31)
  status         ContractStatus @default(DRAFT)

  // RELAÇÕES
  tenantId       String         @db.ObjectId
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId     String         @db.ObjectId
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  renterId       String         @db.ObjectId
  renter         Renter         @relation(fields: [renterId], references: [id], onDelete: Cascade)

  userId         String         @db.ObjectId
  user           User           @relation(fields: [userId], references: [id])

  payments       Payment[]
  documents      Document[]     // O Contrato assinado em si e aditivos

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Payment {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  amount         Float
  dueDate        DateTime
  paymentDate    DateTime?
  status         PaymentStatus @default(PENDING)
  method         PaymentMethod @default(PIX)
  referenceMonth String        // Ex: "04/2026"

  // RELAÇÕES
  contractId     String        @db.ObjectId
  contract       Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)

  renterId       String        @db.ObjectId
  renter         Renter        @relation(fields: [renterId], references: [id], onDelete: Cascade)

  tenantId       String        @db.ObjectId
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId         String?       @db.ObjectId // Quem deu baixa no pagamento
  user           User?         @relation(fields: [userId], references: [id])

  documents      Document[]    // ✅ Aqui ficam os RECIBOS gerados após o pagamento

  createdAt      DateTime      @default(now())
}

model Document {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  name       String       // Nome do arquivo
  type       DocumentType
  url        String       // URL do Cloudinary
  fileKey    String       // ID do Cloudinary (para deleção)
  fileSize   Int
  mimeType   String

  // RELAÇÕES POLIMÓRFICAS (Opcionais)
  tenantId   String       @db.ObjectId
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String?      @db.ObjectId
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  renterId   String?      @db.ObjectId
  renter     Renter?      @relation(fields: [renterId], references: [id], onDelete: SetNull)

  contractId String?      @db.ObjectId
  contract   Contract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)

  paymentId  String?      @db.ObjectId
  payment    Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt  DateTime     @default(now())
}