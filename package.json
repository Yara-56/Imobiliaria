{
  "name": "imobisys-pro-2026",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Gestão Imobiliária - SaaS Multi-tenant",
  "scripts": {
    "// --- 🚀 Desenvolvimento ---": "",
    "dev": "concurrently --kill-others-on-fail -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"bgBlue.bold,bgMagenta.bold\" \"npm run server\" \"npm run client\"",
    "server": "cd backend && npm run dev",
    "client": "cd frontend && npm run dev",
    "kill": "npx kill-port 3001 5173",
    "// --- 💎 Prisma & Database ---": "",
    "db:generate": "cd backend && npx prisma generate",
    "db:studio": "cd backend && npx prisma studio",
    "db:push": "cd backend && npx prisma db push",
    "// --- 🏗️ Build e Produção ---": "",
    "build": "concurrently \"npm run build:server\" \"npm run build:client\"",
    "build:server": "cd backend && npm run build",
    "build:client": "cd frontend && npm run build",
    "start": "cd backend && npm run start",
    "// --- 🛡️ Qualidade e Segurança ---": "",
    "lint": "concurrently \"cd backend && npm run lint\" \"cd frontend && npm run lint\"",
    "test": "concurrently \"cd backend && npm test\" \"cd frontend && npm test\"",
    "security:check": "npm audit && cd backend && npm audit && cd frontend && npm audit",
    "// --- 🧹 Manutenção ---": "",
    "clean": "rm -rf node_modules && rm -rf backend/node_modules && rm -rf frontend/node_modules",
    "reinstall": "npm run clean && npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^7.4.2",
    "@tanstack/react-query": "^5.91.3",
    "@types/mongoose": "^5.11.96",
    "@types/multer": "^2.1.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.564.0",
    "mongoose": "^9.3.1",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.4.2",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@faker-js/faker": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-dropzone": "^4.2.2",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
