    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.1.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "swagger-jsdoc": "^6.2.8"
  }
}