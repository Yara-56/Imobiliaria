{
  "name": "homeflux",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev --filter=@homeflux/*",
    "build": "turbo build",
    "prisma:generate": "turbo prisma:generate",
    "clean": "rimraf .turbo node_modules apps/**/node_modules apps/**/dist",
    "reinstall": "pnpm clean && pnpm install"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0",
    "rimraf": "^5.0.5",
    "turbo": "^2.1.0",
    "typescript": "^5.7.0"
  }
}